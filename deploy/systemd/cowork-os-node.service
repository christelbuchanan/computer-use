[Unit]
Description=CoWork OS (Node-Only, Headless)
After=network.target

[Service]
Type=simple

# Path where you cloned/built CoWork OS on the VPS.
WorkingDirectory=/opt/ChatAndBuild

# Optional env file (LLM keys, data dir, control plane host/port, etc).
EnvironmentFile=-/etc/ChatAndBuild.env

# Node-only daemon: no Electron/Xvfb required.
ExecStart=/usr/bin/node /opt/ChatAndBuild/bin/ChatAndBuildd-node.js

Restart=on-failure
RestartSec=5

# Run as an unprivileged user (recommended).
User=ChatAndBuild
Group=ChatAndBuild

[Install]
WantedBy=multi-user.target

